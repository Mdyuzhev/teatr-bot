# PostgreSQL (отдельный контейнер, порт 5435 — не конфликтует с moex-postgres на 5434)
POSTGRES_HOST=192.168.1.74
POSTGRES_PORT=5435
POSTGRES_DB=teatr_bot
POSTGRES_USER=teatr_user
POSTGRES_PASSWORD=your_strong_password_here

# Anthropic (только для digest_builder.py — не для логики сбора данных)
ANTHROPIC_API_KEY=sk-ant-...

# Telegram
TELEGRAM_BOT_TOKEN=...
TELEGRAM_CHAT_ID=...

# Настройки сбора данных
KUDAGO_DAYS_AHEAD=30
KUDAGO_PAGE_SIZE=100
COLLECTION_HOUR=6
MAX_DIGEST_SHOWS=20

# Claude (дайджест)
DIGEST_MAX_TOKENS=1500
