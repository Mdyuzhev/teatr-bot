# PostgreSQL (порт 5435 — не конфликтует с moex-postgres на 5434)
# Внутри Docker: teatr-postgres (имя сервиса в compose)
# Без Docker:    localhost или IP сервера
POSTGRES_HOST=teatr-postgres
POSTGRES_PORT=5435
POSTGRES_DB=teatr_bot
POSTGRES_USER=teatr_user
POSTGRES_PASSWORD=your_strong_password_here

# Anthropic (только для digest_builder.py — не для логики сбора данных)
ANTHROPIC_API_KEY=sk-ant-...
# Прокси для Anthropic API (vpn-proxy на сервере, обход геоблока)
# Внутри Docker: http://vpn-proxy:8888 (через общую Docker-сеть)
# Без Docker:    http://localhost:8888
ANTHROPIC_PROXY=http://vpn-proxy:8888

# Telegram
TELEGRAM_BOT_TOKEN=...
TELEGRAM_CHAT_ID=...

# Настройки сбора данных
KUDAGO_DAYS_AHEAD=30
KUDAGO_PAGE_SIZE=100
COLLECTION_HOUR=6
MAX_DIGEST_SHOWS=20

# MCP-сервер
MCP_SERVER_URL=http://YOUR_SERVER_IP:8765

# Claude (дайджест)
DIGEST_MAX_TOKENS=1500
